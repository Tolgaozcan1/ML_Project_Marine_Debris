.DS_Store
**/__pycache__/
*.pyc
.claude/

# Raw dataset — large, externally downloadable (see README). Exception:
# watertank-cropped is kept — the presentation notebook loads it directly
# for live classification evaluation and the code-demo cells.
Dataset/marine-debris-fls-datasets/*
!Dataset/marine-debris-fls-datasets/md_fls_dataset
Dataset/marine-debris-fls-datasets/md_fls_dataset/*
!Dataset/marine-debris-fls-datasets/md_fls_dataset/data
Dataset/marine-debris-fls-datasets/md_fls_dataset/data/*
!Dataset/marine-debris-fls-datasets/md_fls_dataset/data/watertank-cropped

# Derived/converted images — regenerable from the raw dataset + conversion scripts.
# Exception: test/ + dataset.yaml are kept — the presentation notebook loads them
# directly for live detection evaluation and the code-demo cells.
Dataset/results/yolo_dataset/train/
Dataset/results/yolo_dataset/val/

# Redundant cached pretrained-COCO downloads (ultralytics re-downloads automatically)
Dataset/yolov8m.pt
Dataset/yolov8n.pt

# Stray ultralytics .val() run artifacts (duplicates of results/yolo_sonar/*)
Dataset/runs/
